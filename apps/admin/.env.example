# ─── Shopify App credentials ──────────────────────────────────────────────────
# Get these from https://partners.shopify.com → Apps → Your App → Configuration
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SHOPIFY_APP_SCOPES=read_products,write_products,read_orders,read_customers,read_discounts,write_discounts,read_price_rules,write_price_rules,read_metaobjects,write_metaobjects,read_themes,read_delivery_customizations,write_delivery_customizations
# Shopify API version used for GraphQL/REST calls (keep in sync with shopify.app.toml)
SHOPIFY_API_VERSION=2026-04

# ─── App URL ──────────────────────────────────────────────────────────────────
HOST=https://your-marginlab-app.vercel.app

# ─── App version ──────────────────────────────────────────────────────────────
# Optional — overrides package.json version in /api/health
APP_VERSION=0.1.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/marginlab

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32+ random characters — used to encrypt Shopify access tokens at rest
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=your-32-char-minimum-encryption-key-here

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Secret passed in Authorization header by Vercel Cron (or your own scheduler)
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ─── Email (transactional) ────────────────────────────────────────────────────
# Used for experiment digest emails and billing alerts
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=MarginLab <noreply@your-domain.com>

# ─── Demo shop (local dev without full OAuth) ─────────────────────────────────
DEMO_SHOP_DOMAIN=your-dev-store.myshopify.com
NEXT_PUBLIC_DEMO_SHOP=your-dev-store.myshopify.com

# ─── ClickHouse (optional — high-volume analytics) ────────────────────────────
# Leave USE_CLICKHOUSE unset (or set to "false") to use Postgres for analytics
# USE_CLICKHOUSE=true
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# Get these from https://sentry.io → Settings → Projects
SENTRY_DSN=https://your-key@o0000000.ingest.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0000000.ingest.sentry.io/0000000
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=marginlab-admin
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ─── Axiom (structured logging) ───────────────────────────────────────────────
# Create a dataset at https://app.axiom.co → Datasets
AXIOM_TOKEN=your_axiom_api_token
AXIOM_DATASET=marginlab
